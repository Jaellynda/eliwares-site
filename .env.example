# PesaPal Configuration
# Get test credentials at: https://developer.pesapal.com/api3-demo-keys.txt
# Production: Register at https://www.pesapal.com/dashboard/account/register

PESAPAL_CONSUMER_KEY=your_consumer_key_here
PESAPAL_CONSUMER_SECRET=your_consumer_secret_here
PESAPAL_ENV=sandbox    # Change to "live" for production
PESAPAL_IPN_ID=your_ipn_id_here   # Get from /api/setup-ipn after deployment

# Site URL for callbacks
NEXT_PUBLIC_SITE_URL=http://localhost:3000
